{
  "app": "Shell Server",
  "version": "0.0.0.1",
  "port": 3000,
  "allowed": {
    "commands": ["ls", "pwd", "date", "echo","whoami", "uptime", "c:\\code\\echo-stuff.cmd"],
    "hosts": ["localhost", "127.0.0.1"],
    "origins": ["http://localhost:5500", "http://127.0.0.1:5500"]
